root = true

# --- Defaults for all files ---
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# --- Python: 4-space indentation ---
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# --- JavaScript / TypeScript / JSX / TSX: 2-space indentation ---
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# --- JSON, YAML, TOML: 2-space indentation ---
[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2

# --- Markdown: preserve trailing spaces (line breaks) ---
[*.md]
trim_trailing_whitespace = false

# --- Makefile: tabs required ---
[Makefile]
indent_style = tab
