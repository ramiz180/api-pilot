# ===== App =====
APP_NAME=api-pilot
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api

# ===== Server =====
HOST=0.0.0.0
PORT=8000

# ===== LLM =====
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://api_pilot:api_pilot_dev@localhost:5432/api_pilot
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true
