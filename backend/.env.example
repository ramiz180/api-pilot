# ===== App =====
APP_NAME=api-pilot
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api

# ===== Server =====
HOST=0.0.0.0
PORT=8000

# ===== LLM =====
# Provider: nvidia_nim (default, free at build.nvidia.com)
#           groq (free at console.groq.com)
#           openai
#           anthropic
#           mock (tests only)
LLM_PROVIDER=nvidia_nim

# Get a free key at https://build.nvidia.com/ — no credit card required
NVIDIA_API_KEY=

# Alternative free provider — no card required at https://console.groq.com/
GROQ_API_KEY=

# Optional fallbacks
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional overrides (rarely needed)
# LLM_BASE_URL=
# LLM_MODEL=

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://api_pilot:api_pilot_dev@localhost:5432/api_pilot
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true
